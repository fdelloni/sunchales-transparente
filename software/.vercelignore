# Archivos y carpetas que NO se suben a Vercel.
# IMPORTANTE: las reglas SIN "/" inicial matchean en cualquier nivel.
# Para excluir solo en la raíz del proyecto, prefijar con "/".

# PDFs descargados (referencia local, no del sitio) — solo en raíz
/data/

# Migrations SQL — Supabase no está conectado en producción todavía
/supabase/

# Scripts auxiliares (descargas de PDFs, etc.) — no del sitio
/scripts/

# Builds y dependencias (Vercel los regenera del package.json)
node_modules/
.next/
out/
build/
dist/

# Logs y archivos del sistema
*.log
.DS_Store

# Archivos de entorno
.env
.env.local

# Scripts batch de Windows (solo locales)
*.bat

# Config de TypeScript de checking adicional
/tsconfig.check.json
