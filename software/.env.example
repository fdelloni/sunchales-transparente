# ====================================================================
# Sunchales Transparente — variables de entorno
# ====================================================================
#
# Para correr LA DEMO LOCAL no necesitas configurar nada acá.
# La app usa los datos en src/lib/data/* y funciona sin Supabase.
#
# Para activar SUPABASE en producción:
#   1. Crear proyecto en https://supabase.com
#   2. Aplicar las migraciones de software/supabase/migrations/
#   3. Cargar estas variables en Vercel → Settings → Environment Variables
#      (NO commitear el archivo .env real al repo)
#
# ====================================================================

# Públicas (incluidas en el bundle del cliente; pueden verse en el navegador)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secreta — solo en el servidor. NUNCA commitear ni exponer.
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend)  — opcional, solo si activamos el despachador de alertas
RESEND_API_KEY=
RESEND_FROM_EMAIL=alertas@sunchales-transparente.org

# WhatsApp (Twilio) — opcional, solo si activamos el despachador de alertas
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
