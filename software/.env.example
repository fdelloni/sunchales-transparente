# ====================================================================
# Sunchales Transparente — variables de entorno
# ====================================================================
#
# Para correr LA DEMO LOCAL no necesitas configurar nada acá.
# La app usa los datos en src/lib/data/* y funciona sin Supabase.
#
# Para activar SUPABASE en producción:
#   1. Crear proyecto en https://supabase.com
#   2. Aplicar las migraciones de software/supabase/migrations/
#   3. Cargar estas variables en Vercel → Settings → Environment Variables
#      (NO commitear el archivo .env real al repo)
#
# ====================================================================

# Públicas (incluidas en el bundle del cliente; pueden verse en el navegador)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secreta — solo en el servidor. NUNCA commitear ni exponer.
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend)  — opcional, solo si activamos el despachador de alertas
RESEND_API_KEY=
RESEND_FROM_EMAIL=alertas@sunchales-transparente.org

# ====================================================================
# WhatsApp Chatbot (Twilio Sandbox o WhatsApp Business API)
# ====================================================================
# Mínimo para que el chatbot responda:
#   - TWILIO_AUTH_TOKEN: validación de firma del webhook
#   - TWILIO_VALIDATE_SIGNATURE=true en producción (false solo en dev local)
# Opcional pero recomendado:
#   - ANTHROPIC_API_KEY: para el modo "pregunta libre" (handler IA con Claude)
# ====================================================================

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Cuando esté en true, el webhook rechaza requests sin firma válida.
TWILIO_VALIDATE_SIGNATURE=false
# Si tu deploy está detrás de un proxy raro, override de la URL pública del webhook
# (debe coincidir EXACTAMENTE con la que cargues en Twilio Console).
# TWILIO_WEBHOOK_URL=https://sunchales-transparente.vercel.app/api/v1/whatsapp

# ====================================================================
# IA conversacional — arquitectura híbrida (RAG + LLM)
# ====================================================================
#
# El chatbot busca PRIMERO en la base documental verificada (gratis,
# sin LLM). Si encuentra match con confianza alta, responde con la cita
# textual y su fuente. Solo cae al LLM si la búsqueda local no alcanza.
#
# Esto reduce el uso del LLM al 10-30% de las consultas y vuelve cada
# respuesta auditable (cita textualmente un documento público).
#
# Soportamos DOS proveedores de LLM (elegís uno):
#
#   * GOOGLE GEMINI 2.5 FLASH (recomendado por costo + tier gratuito):
#       https://aistudio.google.com/app/apikey
#       → seteá GOOGLE_API_KEY
#
#   * ANTHROPIC CLAUDE HAIKU 4.5:
#       https://console.anthropic.com
#       → seteá ANTHROPIC_API_KEY
#
# Si seteás ambos, por defecto se usa Google. Forzar manualmente con:
#   LLM_PROVIDER=google
#   LLM_PROVIDER=anthropic
#
# Si NO seteás ninguno, el chatbot funciona en MODO RAG puro: responde
# todo desde la base documental local. No es "demo": es un modo válido
# de producción para perfiles de bajo costo.
#
# La misma configuración aplica al bot de WhatsApp (handler IA del menú).
# ====================================================================

# Selector explícito (opcional). Si no se setea, auto-detecta.
# LLM_PROVIDER=google

# --- Google Gemini ---
GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-2.5-flash

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
